{
  "name": "@smushytaco/clean-webpack-plugin",
  "version": "1.0.1",
  "description": "A webpack plugin to remove/clean your build folder(s).",
  "type": "module",
  "author": {
    "name": "SmushyTaco",
    "email": "personal@nikanradan.com"
  },
  "private": false,
  "license": "MIT",
  "main": "dist/clean-webpack-plugin.js",
  "module": "dist/clean-webpack-plugin.js",
  "types": "dist/clean-webpack-plugin.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webpack",
    "plugin",
    "clean",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SmushyTaco/clean-webpack-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/SmushyTaco/clean-webpack-plugin/issues"
  },
  "scripts": {
    "clean": "del-cli dist",
    "build": "npm run clean && tsc",
    "prepare": "npm run build",
    "dev": "npm run clean && cross-env NODE_ENV=development babel -w src -d dist --verbose --extensions .ts --ignore */**/*.d.ts,**/**/*.test.ts --source-maps"
  },
  "peerDependencies": {
    "webpack": ">=4.0.0 <6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.9.7",
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "del-cli": "^6.0.0",
    "cross-env": "^7.0.3",
    "@eslint/js": "^9.17.0",
    "@smushytaco/versionchecker": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "typescript-eslint": "^8.18.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1"
  },
  "dependencies": {
    "del": "^8.0.0",
    "is-plain-obj": "^4.1.0"
  },
  "overrides": {
    "glob": "^11.0.0",
    "del": "^8.0.0"
  }
}
